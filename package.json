{
  "name": "visao360",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@11.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "db:seed": "turbo run db:seed",
    "mobile:android": "turbo run android --filter=@visao360/mobile",
    "mobile:ios": "turbo run ios --filter=@visao360/mobile",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:reset": "docker-compose down -v && docker-compose up -d"
  },
  "devDependencies": {
    "@types/ioredis": "^4.28.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^8.0.0",
    "prettier": "^3.3.2",
    "turbo": "^2.0.9",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "trailingComma": "all",
    "printWidth": 100,
    "tabWidth": 2
  },
  "dependencies": {
    "@nestjs/schedule": "^6.1.3",
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@supabase/supabase-js": "^2.105.4",
    "@types/qrcode": "^1.5.6",
    "expo-network": "^55.0.13",
    "expo-server-sdk": "^6.1.0",
    "ioredis": "^5.10.1",
    "next": "^14.2.35",
    "nodemailer": "^8.0.7",
    "qrcode": "^1.5.4",
    "react-native-svg": "^15.15.4"
  }
}
