# ===========================================
# VISÃO360 — Environment Variables
# Copie este arquivo para .env e ajuste os valores
# ===========================================

# Banco de Dados
DATABASE_URL="postgresql://visao360:visao360_pass@localhost:5432/visao360"

# Redis
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD="redis_pass_visao360"

# JWT
JWT_SECRET="super-secret-jwt-key-TROQUE-EM-PRODUCAO-visao360-2024"
JWT_REFRESH_SECRET="super-secret-refresh-key-TROQUE-EM-PRODUCAO-visao360-2024"
JWT_EXPIRES_IN=86400

# Aplicação
NODE_ENV=development
PORT=3001
CORS_ORIGIN="http://localhost:3000"
API_BASE_URL="http://localhost:3001"
LOG_LEVEL=info

# Supabase (Storage e Realtime)
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Next.js (prefixo NEXT_PUBLIC_ é exposto no browser)
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="nextauth-secret-TROQUE-EM-PRODUCAO"

# Stripe — obrigatórios em produção para billing funcionar
# Obtenha em https://dashboard.stripe.com/apikeys (use chaves de TESTE em dev)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Price IDs dos planos (crie em Stripe Dashboard > Products > Prices)
STRIPE_PRICE_STARTER=""
STRIPE_PRICE_PROFESSIONAL=""
STRIPE_PRICE_ENTERPRISE=""

# URL pública do frontend (usado nos redirects do Stripe após checkout)
FRONTEND_URL="http://localhost:3000"
