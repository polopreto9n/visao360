# Visao360 AWS single-instance example.
# Copy to .env.aws on the EC2 host and replace every CHANGE_ME value.

NODE_ENV=production
LOG_LEVEL=info

# Public URLs for the first EC2 test. Replace with your EC2 public IP or domain.
PUBLIC_WEB_URL=http://CHANGE_ME_EC2_PUBLIC_IP:3000
PUBLIC_API_BASE_URL=http://CHANGE_ME_EC2_PUBLIC_IP:3001
CORS_ORIGIN=http://CHANGE_ME_EC2_PUBLIC_IP:3000
API_BASE_URL=http://CHANGE_ME_EC2_PUBLIC_IP:3001
NEXT_PUBLIC_API_URL=http://CHANGE_ME_EC2_PUBLIC_IP:3001/api/v1
NEXTAUTH_URL=http://CHANGE_ME_EC2_PUBLIC_IP:3000

# App secrets. Generate long random values before production use.
JWT_SECRET=CHANGE_ME_MIN_32_CHARS_RANDOM_VALUE
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_MIN_32_CHARS_RANDOM_VALUE
JWT_EXPIRES_IN=86400
NEXTAUTH_SECRET=CHANGE_ME_MIN_32_CHARS_RANDOM_VALUE

# Local Postgres container for the low-cost EC2 migration test.
POSTGRES_USER=visao360
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DATABASE_PASSWORD
POSTGRES_DB=visao360
DATABASE_URL=postgresql://visao360:CHANGE_ME_STRONG_DATABASE_PASSWORD@postgres:5432/visao360
DB_POOL_SIZE=5

# Local Redis container for the low-cost EC2 migration test.
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

# Optional external services. Keep blank if not configured yet.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
