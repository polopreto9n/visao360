{
  "name": "@visao360/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "lint": "eslint src/ --ext .ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.8",
    "@nestjs/core": "^10.3.8",
    "@nestjs/platform-express": "^10.3.8",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/config": "^3.2.2",
    "@nestjs/swagger": "^7.3.1",
    "@nestjs/throttler": "^5.1.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "class-validator": "^0.14.1",
    "class-transformer": "^0.5.1",
    "bcryptjs": "^2.4.3",
    "swagger-ui-express": "^5.0.1",
    "nestjs-pino": "^4.1.0",
    "pino-http": "^10.1.0",
    "pino-pretty": "^11.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "@visao360/database": "*",
    "@visao360/shared": "*"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "@nestjs/testing": "^10.3.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "typescript": "^5.4.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "supertest": "^7.0.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.12",
    "ts-jest": "^29.1.4"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": { "^.+\\.(t|j)s$": "ts-jest" },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/*.module.ts",
      "!**/*.dto.ts",
      "!**/*.entity.ts",
      "!**/main.ts",
      "!**/*.decorator.ts",
      "!**/*.guard.ts",
      "!**/*.filter.ts",
      "!**/*.interceptor.ts",
      "!**/*.middleware.ts",
      "!**/*.strategy.ts"
    ],
    "coverageDirectory": "../coverage",
    "coverageReporters": ["text", "lcov", "html"],
    "coverageThreshold": {
      "global": {
        "branches": 50,
        "functions": 60,
        "lines": 60,
        "statements": 60
      },
      "./src/auth/auth.service.ts": {
        "branches": 80,
        "functions": 90,
        "lines": 90,
        "statements": 90
      },
      "./src/work-orders/work-orders.service.ts": {
        "branches": 70,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "testEnvironment": "node",
    "verbose": true
  }
}
